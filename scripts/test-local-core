#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CORE_PATH="${COMFYGIT_CORE_PATH:-"$ROOT/../comfygit/packages/core"}"
STUDIO_RUNTIME_PATH="${COMFYGIT_STUDIO_PATH:-"$ROOT/../comfygit/packages/studio-runtime"}"

if [[ ! -f "$CORE_PATH/pyproject.toml" ]]; then
  echo "Could not find local comfygit-core at: $CORE_PATH" >&2
  echo "Set COMFYGIT_CORE_PATH=/path/to/comfygit/packages/core" >&2
  exit 1
fi

if [[ ! -f "$STUDIO_RUNTIME_PATH/pyproject.toml" ]]; then
  echo "Could not find local comfygit-studio runtime at: $STUDIO_RUNTIME_PATH" >&2
  echo "Set COMFYGIT_STUDIO_PATH=/path/to/comfygit/packages/studio-runtime" >&2
  exit 1
fi

if [[ "$#" -eq 0 ]]; then
  set -- testing/unit -q
fi

cd "$ROOT"

COMFYGIT_DEV_CORE_PATH="$CORE_PATH" \
COMFYGIT_DEV_STUDIO_PATH="$STUDIO_RUNTIME_PATH" \
  uv run --project "$ROOT/testing" pytest "$@"
